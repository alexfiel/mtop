generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------
// Better-Auth Core Models
// ---------------------------------------------
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom Role Field
  role Role @default(USER)

  sessions  Session[]
  accounts  Account[]
  auditLogs AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

enum Role {
  ADMIN
  SECRETARY
  ENFORCER
  INSPECTOR
  CLERK
  CASHIER
  VIEWER
  USER
}

// ---------------------------------------------
// MTOP Core Models
// ---------------------------------------------

enum FranchiseStatus {
  PENDING
  FOR_BILLING
  FOR_PAYMENT
  FOR_SP_APPROVAL
  APPROVED
  PUBLISHED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum TricycleStatus {
  PENDING
  FOR_SP_APPROVAL
  APPROVED
  PUBLISHED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum DriverStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

enum PermitStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ApplicationStatus {
  PENDING
  FOR_SP_APPROVAL
  APPROVED
  PUBLISHED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum DocumentType {
  NEW_APPLICATION
  RENEWAL
  RETIREMENT
}

model BodyNumber {
  bodyNumber Int @id
  franchiseId String? @unique
  franchise Franchise? @relation(fields: [franchiseId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Franchise {
  id          String   @id @default(cuid())
  franchiseNo String   @unique
  ownerName   String
  address     String
  contactNo   String
  email       String   @unique
  dateOfBirth DateTime

  // Additional Franchise Details
  resolutionNo    String?
  approvedOn      DateTime?
  areaOfOperation String?

  status    String    @default("PENDING") // PENDING, FOR_SP_APPROVAL, APPROVED, PUBLISHED, ACTIVE, SUSPENDED, REVOKED
  isRenewal Boolean   @default(false)
  issuedAt  DateTime  @default(now())
  expiresAt DateTime?

  tricycle Tricycle?

  bodyNumber BodyNumber?

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  franchiseTransactions FranchiseTransaction[]
}

model FranchiseTransaction {
  id              String    @id @default(cuid())
  franchiseId     String
  franchise       Franchise @relation(fields: [franchiseId], references: [id])
  transactionType String //renewal, payment, etc
  paymentStatus   String //paid, unpaid, etc.
  amount          Float
  paymentDate     DateTime
  orNumber        String    @unique
  remarks         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  middleName     String?
  licenseNo      String   @unique
  address        String
  contactNo      String
  email          String   @unique
  dateOfBirth    DateTime
  status         String   @default("ACTIVE") // ACTIVE, SUSPENDED, REVOKED
  profilePicture String?

  mainTricycles  Tricycle[]  @relation("MainDriver")
  extraTricycles Tricycle[]  @relation("ExtraDriver")
  violations     Violation[]
  documents      Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tricycle {
  id         String @id @default(cuid())
  make       String
  model      String
  color      String
  plateNo    String @unique
  chassisNo  String @unique
  motorNo    String @unique
  bodyNumber String @unique
  status     String @default("ACTIVE") // ACTIVE, SUSPENDED, REVOKED

  mainDriverId String?
  mainDriver   Driver? @relation("MainDriver", fields: [mainDriverId], references: [id])

  extraDriverId String?
  extraDriver   Driver? @relation("ExtraDriver", fields: [extraDriverId], references: [id])

  franchiseId String    @unique
  franchise   Franchise @relation(fields: [franchiseId], references: [id])

  permits    Permit[]
  violations Violation[]
  documents  Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permit {
  id        String   @id @default(cuid())
  permitNo  String   @unique
  status    String   @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED
  issuedAt  DateTime @default(now())
  expiresAt DateTime

  tricycleId String
  tricycle   Tricycle @relation(fields: [tricycleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ViolationType is customizable by admin
model ViolationType {
  id          String @id @default(cuid())
  code        String @unique
  description String
  fineAmount  Float

  violations Violation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Violation {
  id       String   @id @default(cuid())
  ticketNo String   @unique
  remarks  String?
  status   String   @default("UNPAID") // UNPAID, PAID, SETTLED
  issuedAt DateTime @default(now())

  violationTypeId String
  type            ViolationType @relation(fields: [violationTypeId], references: [id])

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  tricycleId String?
  tricycle   Tricycle? @relation(fields: [tricycleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id           String @id @default(cuid())
  fileUrl      String
  fileType     String // IMAGE, PDF, etc.
  documentType String // e.g., DRIVERS_LICENSE, OR_CR, CLEARANCE

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  tricycleId String?
  tricycle   Tricycle? @relation(fields: [tricycleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeeRule {
  id              String  @id @default(cuid())
  applicationType String // "NEW", "RENEWAL", "RETIREMENT"
  description     String // e.g., "Mayor's Permit Fee", "Filing Fee", "Penalty"
  amount          Float
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------
// Universal Audit Log
// ---------------------------------------------
model AuditLog {
  id       String @id @default(cuid())
  entity   String // e.g. "Tricycle", "Driver", "Franchise"
  entityId String // The ID of the record being changed
  action   String // "CREATE", "UPDATE", "DELETE"
  changes  String // JSON string of changes

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model ItemAccounts {
  id              String  @id @default(cuid())
  account_name    String
  account_number  String  @unique
  default_amount  Float   @default(0)
  isActive        Boolean @default(true)
  fundtype        String  //General Fund, Trust Fund, Motorized Vehicle Fund
  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

